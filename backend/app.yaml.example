runtime: python312
instance_class: F1
entrypoint: uvicorn app.main:app --host 0.0.0.0 --port $PORT

env_variables:
  FIREBASE_PROJECT_ID: "tu-firebase-project-id"
  ROBOFLOW_API_KEY: "tu_roboflow_api_key"
  ROBOFLOW_PROJECT: "tu_project_name"
  ROBOFLOW_VERSION: "1"

automatic_scaling:
  min_instances: 0
  max_instances: 1
  target_cpu_utilization: 0.65

handlers:
  - url: /.*
    script: auto
    secure: always
